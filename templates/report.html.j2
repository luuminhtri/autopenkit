<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ metadata.project_name | default("AutoPenKit", true) }} Security Assessment Report</title>
  <style>
    :root {
      --bg: #f4f6f8;
      --panel: #ffffff;
      --ink: #1d2733;
      --muted: #5c6b7a;
      --line: #d8dee5;
      --line-soft: #edf1f5;
      --accent: #0f766e;
      --critical-bg: #fee2e2;
      --critical-fg: #991b1b;
      --high-bg: #ffedd5;
      --high-fg: #9a3412;
      --medium-bg: #fef3c7;
      --medium-fg: #92400e;
      --low-bg: #dcfce7;
      --low-fg: #166534;
      --info-bg: #dbeafe;
      --info-fg: #1d4ed8;
    }
    * {
      box-sizing: border-box;
    }
    body {
      background: var(--bg);
      color: var(--ink);
      font-family: Arial, Helvetica, sans-serif;
      line-height: 1.55;
      margin: 0;
    }
    main {
      margin: 0 auto;
      max-width: 1120px;
      padding: 32px 20px 48px;
    }
    .cover {
      background: var(--panel);
      border-top: 6px solid var(--accent);
      box-shadow: 0 10px 28px rgba(16, 24, 40, 0.08);
      margin-bottom: 20px;
      padding: 34px;
    }
    .eyebrow {
      color: var(--accent);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      margin: 0 0 8px;
      text-transform: uppercase;
    }
    h1, h2, h3 {
      line-height: 1.2;
      margin: 0;
    }
    h1 {
      font-size: 34px;
      margin-bottom: 14px;
    }
    h2 {
      border-bottom: 1px solid var(--line);
      font-size: 20px;
      margin-bottom: 16px;
      padding-bottom: 10px;
    }
    h3 {
      font-size: 18px;
      margin-bottom: 12px;
    }
    p {
      margin: 0 0 12px;
    }
    .subtitle {
      color: var(--muted);
      max-width: 760px;
    }
    .report-meta {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      margin-top: 26px;
    }
    .meta-item, .metric, section {
      background: var(--panel);
      border: 1px solid var(--line);
    }
    .meta-item, .metric {
      padding: 14px;
    }
    .label {
      color: var(--muted);
      display: block;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .value {
      display: block;
      font-size: 15px;
      font-weight: 700;
      overflow-wrap: anywhere;
    }
    section {
      margin-bottom: 20px;
      padding: 24px;
    }
    .summary-grid {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }
    .metric strong {
      display: block;
      font-size: 26px;
      margin-top: 4px;
    }
    table {
      border-collapse: collapse;
      font-size: 14px;
      width: 100%;
    }
    th, td {
      border-bottom: 1px solid var(--line-soft);
      padding: 10px 8px;
      text-align: left;
      vertical-align: top;
    }
    th {
      background: #f8fafc;
      color: #334155;
      font-size: 12px;
      text-transform: uppercase;
    }
    code, pre {
      background: #f8fafc;
      border: 1px solid var(--line-soft);
      color: #243447;
      font-family: Consolas, Menlo, Monaco, monospace;
    }
    code {
      border-radius: 4px;
      padding: 2px 5px;
    }
    pre {
      border-radius: 6px;
      margin: 8px 0 16px;
      overflow-x: auto;
      padding: 12px;
      white-space: pre-wrap;
    }
    .badge {
      border-radius: 999px;
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      line-height: 1;
      padding: 6px 9px;
      text-transform: uppercase;
    }
    .badge.critical { background: var(--critical-bg); color: var(--critical-fg); }
    .badge.high { background: var(--high-bg); color: var(--high-fg); }
    .badge.medium { background: var(--medium-bg); color: var(--medium-fg); }
    .badge.low { background: var(--low-bg); color: var(--low-fg); }
    .badge.info { background: var(--info-bg); color: var(--info-fg); }
    .finding {
      border: 1px solid var(--line);
      margin-top: 16px;
    }
    .finding-header {
      align-items: flex-start;
      background: #f8fafc;
      border-bottom: 1px solid var(--line);
      display: flex;
      gap: 14px;
      justify-content: space-between;
      padding: 16px;
    }
    .finding-body {
      padding: 16px;
    }
    .finding-title {
      margin: 0;
    }
    .two-column {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }
    .callout {
      background: #f8fafc;
      border-left: 4px solid var(--accent);
      padding: 12px 14px;
    }
    a {
      color: #0f5f9c;
    }
    @media print {
      body {
        background: #ffffff;
      }
      main {
        max-width: none;
        padding: 0;
      }
      .cover, section {
        box-shadow: none;
        break-inside: avoid;
      }
      .finding {
        break-inside: avoid;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
    }
  </style>
</head>
<body>
  <main>
    <header class="cover">
      <p class="eyebrow">Security Report</p>
      <h1>{{ metadata.project_name | default("AutoPenKit", true) }}</h1>
      <p class="subtitle">Automated scan results consolidated from normalized scanner findings and AI-assisted analysis.</p>
      <div class="report-meta">
        <div class="meta-item">
          <span class="label">Target</span>
          <span class="value"><code>{{ metadata.target | default("unknown", true) }}</code></span>
        </div>
        <div class="meta-item">
          <span class="label">Profile</span>
          <span class="value">{{ metadata.profile | default("unknown", true) }}</span>
        </div>
        <div class="meta-item">
          <span class="label">Status</span>
          <span class="value">{{ metadata.scan_status | default("unknown", true) }}</span>
        </div>
        <div class="meta-item">
          <span class="label">Overall Risk</span>
          <span class="value">{{ risk_level }}</span>
        </div>
        <div class="meta-item">
          <span class="label">Started</span>
          <span class="value">{{ metadata.started_at | default("unknown", true) }}</span>
        </div>
        <div class="meta-item">
          <span class="label">Generated</span>
          <span class="value">{{ generated_at }}</span>
        </div>
      </div>
    </header>

    <section>
      <h2>Executive Summary</h2>
      <div class="summary-grid">
        <div class="metric"><span class="label">Live Assets</span><strong>{{ metadata.total_assets | default(assets.live_urls | default([]) | length, true) }}</strong></div>
        <div class="metric"><span class="label">Final Findings</span><strong>{{ finding_count }}</strong></div>
        <div class="metric"><span class="label">AI Analyzed</span><strong>{{ metadata.total_ai_analyzed_findings | default(ai_analyzed_count, true) }}</strong></div>
        <div class="metric"><span class="label">Risk Rating</span><strong>{{ risk_level }}</strong></div>
      </div>
    </section>

    <section>
      <h2>Severity Breakdown</h2>
      <table>
        <thead>
          <tr>
            <th>Severity</th>
            <th>Count</th>
          </tr>
        </thead>
        <tbody>
          {% for severity, count in findings_by_severity.items() %}
          <tr>
            <td><span class="badge {{ severity }}">{{ severity }}</span></td>
            <td>{{ count }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Scope</h2>
      {% if assets.live_urls %}
      <table>
        <thead>
          <tr><th>Live URL</th></tr>
        </thead>
        <tbody>
          {% for url in assets.live_urls %}
          <tr><td><code>{{ url }}</code></td></tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p>No live URLs were recorded.</p>
      {% endif %}
    </section>

    <section>
      <h2>Finding Overview</h2>
      {% if findings %}
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Severity</th>
            <th>Confidence</th>
            <th>Finding</th>
            <th>URL</th>
          </tr>
        </thead>
        <tbody>
          {% for finding in findings %}
          <tr>
            <td>{{ finding.finding_id }}</td>
            <td><span class="badge {{ finding.final_severity }}">{{ finding.final_severity }}</span></td>
            <td>{{ finding.ai_confidence or "unknown" }}</td>
            <td>{{ finding.ai_vulnerability_title or finding.vulnerability_name }}</td>
            <td><code>{{ finding.url }}</code></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p>No findings were produced.</p>
      {% endif %}
    </section>

    <section>
      <h2>Detailed Findings</h2>
      {% for finding in findings %}
      <article class="finding">
        <div class="finding-header">
          <div>
            <h3 class="finding-title">{{ finding.finding_id }} - {{ finding.ai_vulnerability_title or finding.vulnerability_name }}</h3>
            <p>{{ finding.source_tool }} / {{ finding.template_id }}</p>
          </div>
          <span class="badge {{ finding.final_severity }}">{{ finding.final_severity }}</span>
        </div>
        <div class="finding-body">
          <div class="two-column">
            <div>
              <span class="label">Affected Location</span>
              <p><code>{{ finding.ai_affected_location or finding.url }}</code></p>
            </div>
            <div>
              <span class="label">AI Confidence</span>
              <p>{{ finding.ai_confidence or "unknown" }} | {{ finding.ai_status }}</p>
            </div>
          </div>
          <span class="label">Evidence</span>
          <pre>{{ finding.evidence }}</pre>
          <div class="callout">
            <strong>How to Access and Verify</strong>
            {% if finding.ai_access_steps %}
            <ol>
              {% for step in finding.ai_access_steps %}
              <li>{{ step }}</li>
              {% endfor %}
            </ol>
            {% else %}
            <ol>
              <li>Open the affected location from an authorized testing environment.</li>
              <li>Compare the observed page or HTTP response with the scanner evidence.</li>
              <li>Confirm whether the behavior is expected for this website.</li>
            </ol>
            {% endif %}
          </div>
          <div class="callout">
            <strong>Analysis</strong>
            <p>{{ finding.ai_explanation or "No AI explanation was available. Manual validation is recommended." }}</p>
          </div>
          <p><strong>Business Impact:</strong> {{ finding.ai_business_impact or "Manual review required." }}</p>
          <p><strong>Recommended Remediation:</strong> {{ finding.ai_remediation or "Validate the finding and follow the source tool guidance." }}</p>
          {% if finding.ai_owner_remediation_steps %}
          <p><strong>Owner Remediation Steps</strong></p>
          <ol>
            {% for step in finding.ai_owner_remediation_steps %}
            <li>{{ step }}</li>
            {% endfor %}
          </ol>
          {% endif %}
          {% if finding.ai_fix_validation_steps %}
          <p><strong>How to Confirm Fixed</strong></p>
          <ol>
            {% for step in finding.ai_fix_validation_steps %}
            <li>{{ step }}</li>
            {% endfor %}
          </ol>
          {% endif %}
          {% if finding.ai_likely_false_positive %}
          <p><strong>False Positive Note:</strong> {{ finding.ai_false_positive_reason or "AI marked this finding as a likely false positive." }}</p>
          {% endif %}
          {% if finding.ai_references %}
          <p><strong>References</strong></p>
          <ul>
            {% for reference in finding.ai_references %}
            <li><a href="{{ reference }}">{{ reference }}</a></li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
      </article>
      {% else %}
      <p>No detailed findings are available.</p>
      {% endfor %}
    </section>

    <section>
      <h2>Review Notes</h2>
      <ul>
        <li>AI-assisted analysis is intended to support triage and should be manually validated before remediation decisions.</li>
        <li>Severity may be adjusted during final review when business context or exploitability differs from scanner output.</li>
      </ul>
    </section>
  </main>
</body>
</html>
